{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RateLimit": {
    "Algorithm": "TokenBucket",
    "PermitLimit": 10,
    "WindowSeconds": 1
  }
}
